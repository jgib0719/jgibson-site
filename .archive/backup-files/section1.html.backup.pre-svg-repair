        #studyModal { display:none; opacity:0; }
        #studyModal.visible { display:flex; opacity:1; }
        #modalContent { transform:scale(.95); opacity:0; }
        #modalContent.visible { transform:scale(1); opacity:1; }
        #modalVisual { background:radial-gradient(circle,#1e293b,#0f172a); border-bottom:1px solid #334155; }
        
        .studied { position: relative; }
        .studied::after {
            content: '\f058';
            font-family: 'Font Awesome 6 Free';
            font-weight: 900;
            position: absolute;
            top: 8px;
            right: 8px;
            color: #22c55e;
            font-size: 18px;
            z-index: 10;
        }
