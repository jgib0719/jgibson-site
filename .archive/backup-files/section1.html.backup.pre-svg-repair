    <style>
        body { font-family: 'Rajdhani', sans-serif; background-color:#0f172a; }
        .title-font { font-family: 'Orbitron', sans-serif; }
        .topic-card { background-color:#1e293b; border:1px solid #334155; transition:transform .3s, box-shadow .3s; box-shadow:0 4px 6px rgba(0,0,0,.2), inset 0 0 10px rgba(79,70,229,.2);} 
